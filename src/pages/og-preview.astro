---
import { OPENPLANNER_URL } from 'astro:env/client'
import type { OpenPlannerType } from '../type'

const response = await fetch(OPENPLANNER_URL)
const data: OpenPlannerType = await response.json()
const sampleSpeakers = data.speakers.slice(0, 4)
const staticPages = ['team', 'speakers', 'schedule', 'jobs', 'location', 'anecdotes', 'jeu', 'coc', '404']
---

<html>
    <head>
        <meta charset="utf-8" />
        <title>OG preview</title>
        <style>
            body {
                font-family: sans-serif;
                background: #1a1a1a;
                color: #eee;
                padding: 24px;
                margin: 0;
            }
            h1 {
                margin: 0 0 16px;
            }
            h2 {
                margin: 28px 0 10px;
                font-size: 16px;
                opacity: 0.85;
            }
            .grid {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
                gap: 16px;
            }
            .tile {
                background: #000;
                border-radius: 6px;
                overflow: hidden;
            }
            .tile img {
                width: 100%;
                height: auto;
                display: block;
            }
            .tile figcaption {
                padding: 8px 12px;
                font-size: 13px;
                opacity: 0.75;
            }
        </style>
    </head>
    <body>
        <h1>OG image previews</h1>

        <h2>Default</h2>
        <div class="grid">
            <figure class="tile">
                <img src="/og/default.png" alt="default" />
                <figcaption>/og/default.png</figcaption>
            </figure>
        </div>

        <h2>Static pages</h2>
        <div class="grid">
            {
                staticPages.map((p) => (
                    <figure class="tile">
                        <img src={`/og/pages/${p}.png`} alt={p} />
                        <figcaption>/{p}</figcaption>
                    </figure>
                ))
            }
        </div>

        <h2>Speakers (sample)</h2>
        <div class="grid">
            {
                sampleSpeakers.map((s) => (
                    <figure class="tile">
                        <img src={`/og/speakers/${s.id}.png`} alt={s.name} />
                        <figcaption>{s.name}</figcaption>
                    </figure>
                ))
            }
        </div>
    </body>
</html>
