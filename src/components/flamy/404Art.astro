<canvas id="artCanvas"></canvas>

<script>
    import { flamySimple } from './flamySimple.js'

    const canvas = document.getElementById('artCanvas') as HTMLCanvasElement
    const ctx = canvas.getContext('2d')

    if (ctx) {
        // Match parent width, keep fixed height
        const parent = canvas.parentElement
        const logicalWidth = parent ? parent.clientWidth : 600
        const logicalHeight = 400

        // Get the device pixel ratio, falling back to 1
        const dpr = window.devicePixelRatio || 1

        // Set the display size of the canvas (CSS pixels)
        canvas.style.width = logicalWidth + 'px'
        canvas.style.height = logicalHeight + 'px'

        // Set the actual size of the drawing buffer
        canvas.width = logicalWidth * dpr
        canvas.height = logicalHeight * dpr

        // Function to generate a random number within a range
        const getRandom = (min: number, max: number): number => Math.random() * (max - min) + min

        const numFlamingos = 4
        const flamingos = []

        const pinkColors = ['#E8597C', '#D63F63', '#F472B6', '#EC4899', '#DB2777', '#E05A8D']

        for (let i = 0; i < numFlamingos; i++) {
            const color = pinkColors[Math.floor(Math.random() * pinkColors.length)]
            const scale = getRandom(0.7, 1.2)
            const facing = Math.random() > 0.3 ? 1 : -1
            const oneLeg = Math.random() > 0.6

            flamingos.push({
                offsetX: getRandom(120, logicalWidth - 120),
                offsetY: getRandom(120, logicalHeight - 160),
                headRadius: getRandom(10, 14) * scale,
                neckLength: getRandom(70, 110) * scale,
                bodyRadiusX: getRandom(35, 50) * scale,
                bodyRadiusY: getRandom(22, 32) * scale,
                legLength: getRandom(90, 130) * scale,
                color: color,
                facing: facing,
                oneLeg: oneLeg,
            })
        }

        // Sort by Y position for depth ordering
        flamingos.sort((a, b) => a.offsetY - b.offsetY)

        flamingos.forEach((flamingoProps) => {
            flamySimple(ctx, flamingoProps)
        })
    }
</script>
