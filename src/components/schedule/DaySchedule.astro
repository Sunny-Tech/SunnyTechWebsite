---
import type { Track } from '../../type'
import type { AugmentedSession, CrossDaySession } from '../../utils/scheduleSearch'
import ScheduleSessionCell from './ScheduleSessionCell.astro'
import ScheduleEmptyState from './ScheduleEmptyState.astro'

interface Props {
    tracks: Track[]
    sessions: AugmentedSession[]
    crossDaySessions?: CrossDaySession[]
}

const { tracks, sessions, crossDaySessions = [] } = Astro.props

const TIME_COLUMN_WIDTH = '60px'
const TRACK_MIN_WIDTH = '120px'

const formatHM = (date: Date) => date.toLocaleTimeString('fr', { hour: '2-digit', minute: '2-digit' })

const uniqueTimeSlots = Array.from(
    new Set(sessions.filter((s) => s.dateStart).map((s) => formatHM(new Date(s.dateStart!))))
).sort()

const gridTemplateColumns = `${TIME_COLUMN_WIDTH} repeat(${tracks.length}, minmax(${TRACK_MIN_WIDTH}, 1fr))`

const cellsToRender = sessions
    .map((session) => {
        if (!session.dateStart || !session.trackId) return null
        const rowStart = uniqueTimeSlots.findIndex((t) => t === formatHM(new Date(session.dateStart!))) + 2
        const trackIndex = tracks.findIndex((t) => t.id === session.trackId)
        if (rowStart < 2 || trackIndex === -1) return null
        return { session, rowStart, trackIndex }
    })
    .filter((cell): cell is { session: AugmentedSession; rowStart: number; trackIndex: number } => cell !== null)
---

<ScheduleEmptyState crossDaySessions={crossDaySessions} />

<div>
    <div class="day-schedule" style={{ gridTemplateColumns }}>
        {/* Empty cell for top-left corner */}
        <div class="day-schedule-tracks-zero"></div>

        <div class="day-schedule-tracks" style={{ gridTemplateColumns: `repeat(${tracks.length}, 1fr)` }}>
            {tracks.map((track) => <div class="day-schedule-track">{track.name}</div>)}
        </div>

        {
            uniqueTimeSlots.map((time, index) => (
                <div class="day-schedule-time" data-time-row={index + 2} style={{ gridRow: index + 2 }}>
                    <span>{time.split(':')[0]}</span>
                    <span class="day-schedule-time-minute">{time.split(':')[1]}</span>
                </div>
            ))
        }

        {
            cellsToRender.map(({ session, rowStart, trackIndex }) => (
                <ScheduleSessionCell session={session} rowStart={rowStart} trackIndex={trackIndex} />
            ))
        }
    </div>
</div>

<style>
    .day-schedule-time[hidden] {
        display: none;
    }

    .day-schedule {
        position: relative;

        > * + * {
            margin-top: var(--s0);
        }

        @media (min-width: 912px) {
            display: grid;
            gap: var(--s0);
            grid-auto-rows: minmax(100px, auto);

            > * + * {
                margin-top: 0;
            }
        }
    }

    .day-schedule-tracks-zero {
        display: none;

        @media (min-width: 912px) {
            grid-column: 0;
            grid-row: 0;
        }
    }

    .day-schedule-tracks {
        display: none;

        @media (min-width: 912px) {
            grid-column: 2 / -1;
            grid-row: 1;
            display: grid;
            position: sticky;
            top: calc(4rem + 1px);
            background-color: var(--background);
            z-index: 2;
            overflow: hidden;
            border-bottom: 1px solid var(--line);
        }
    }

    .day-schedule-track {
        position: relative;
        text-align: center;
        font-weight: bold;
        padding: var(--s0);
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 100%;

        &:not(:last-child)::after {
            content: '';
            position: absolute;
            right: 0;
            top: 50%;
            transform: translateY(-50%);
            width: 1px;
            height: 70%;
            max-height: 100%;
            background-color: var(--line);
        }
    }

    .day-schedule-time {
        display: none;

        @media (min-width: 912px) {
            grid-column: 1;
            text-align: right;
            padding: var(--s0) var(--s0) 0 0;
            display: flex;
            align-items: flex-start;
            justify-content: flex-end;
            font-weight: 500;
            font-size: 1.6em;
        }
    }

    .day-schedule-time-minute {
        font-size: 0.8em;
        opacity: 0.7;
        margin: 2px 0 0 var(--s-3);
    }
</style>
