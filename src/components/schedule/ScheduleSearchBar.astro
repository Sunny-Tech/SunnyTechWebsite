---
// Client-side schedule filter bar. Looks up cells/time rows/cross-day cards
// rendered by sibling schedule components and toggles their `hidden` state.
---

<schedule-search class="schedule-search-wrapper">
    <div class="schedule-search">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
            <path
                fill="currentColor"
                d="M9.5 3A6.5 6.5 0 0 1 16 9.5c0 1.61-.59 3.09-1.56 4.23l.27.27h.79l5 5l-1.5 1.5l-5-5v-.79l-.27-.27A6.52 6.52 0 0 1 9.5 16A6.5 6.5 0 0 1 3 9.5A6.5 6.5 0 0 1 9.5 3m0 2C7 5 5 7 5 9.5S7 14 9.5 14S14 12 14 9.5S12 5 9.5 5"
            ></path>
        </svg>
        <input
            type="search"
            class="schedule-search-input"
            placeholder="Rechercher…"
            aria-label="Rechercher dans le programme"
            autocomplete="off"
        />
        <button type="button" class="schedule-search-clear" aria-label="Effacer la recherche" hidden>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
                <path
                    fill="currentColor"
                    d="M19 6.41L17.59 5L12 10.59L6.41 5L5 6.41L10.59 12L5 17.59L6.41 19L12 13.41L17.59 19L19 17.59L13.41 12z"
                ></path>
            </svg>
        </button>
    </div>
</schedule-search>

<script>
    type Cell = HTMLElement
    type TimeRow = HTMLElement
    type CrossCard = HTMLElement

    class ScheduleSearch extends HTMLElement {
        connectedCallback() {
            const input = this.querySelector<HTMLInputElement>('.schedule-search-input')
            const clearBtn = this.querySelector<HTMLButtonElement>('.schedule-search-clear')
            if (!input) return

            const cells = Array.from(document.querySelectorAll<Cell>('.day-schedule-cell'))
            const timeRows = Array.from(document.querySelectorAll<TimeRow>('.day-schedule-time'))
            const crossCards = Array.from(document.querySelectorAll<CrossCard>('.schedule-cross-day-card'))
            const empty = document.querySelector<HTMLElement>('.schedule-search-empty')
            const crossDay = document.querySelector<HTMLElement>('.schedule-cross-day-hint')

            const apply = () => {
                const query = input.value.trim().toLowerCase()
                if (clearBtn) clearBtn.hidden = !input.value

                const { occupiedRows, visibleCells } = this.filterCells(cells, query)
                const rowMap = this.collapseRows(occupiedRows, query)

                this.repositionTimeRows(timeRows, rowMap, query, occupiedRows)
                this.repositionCells(visibleCells, rowMap, query)

                this.toggleEmptyState(empty, crossDay, crossCards, visibleCells.length, query)
            }

            input.addEventListener('input', apply)
            clearBtn?.addEventListener('click', () => {
                input.value = ''
                input.focus()
                apply()
            })
        }

        private filterCells(cells: Cell[], query: string) {
            const occupiedRows = new Set<number>()
            const visibleCells: Cell[] = []

            for (const cell of cells) {
                const match = !query || (cell.dataset.search || '').includes(query)
                cell.hidden = !match
                if (!match) continue

                visibleCells.push(cell)
                const start = Number(cell.dataset.rowStart)
                const span = Number(cell.dataset.rowSpan) || 1
                if (Number.isNaN(start)) continue
                for (let r = start; r < start + span; r++) occupiedRows.add(r)
            }

            return { occupiedRows, visibleCells }
        }

        /** Map original row index → consecutive index so empty rows collapse. */
        private collapseRows(occupied: Set<number>, query: string): Map<number, number> {
            const map = new Map<number, number>()
            if (!query) return map
            const sorted = [...occupied].sort((a, b) => a - b)
            sorted.forEach((row, i) => map.set(row, i + 2))
            return map
        }

        private repositionTimeRows(rows: TimeRow[], rowMap: Map<number, number>, query: string, occupied: Set<number>) {
            for (const row of rows) {
                const original = Number(row.dataset.timeRow)
                if (!query) {
                    row.hidden = false
                    row.style.gridRow = String(original)
                } else if (occupied.has(original)) {
                    row.hidden = false
                    row.style.gridRow = String(rowMap.get(original))
                } else {
                    row.hidden = true
                }
            }
        }

        private repositionCells(cells: Cell[], rowMap: Map<number, number>, query: string) {
            for (const cell of cells) {
                const start = Number(cell.dataset.rowStart)
                const span = Number(cell.dataset.rowSpan) || 1
                const row = query ? rowMap.get(start) : start
                cell.style.gridRow = `${row} / span ${span}`
            }
        }

        private toggleEmptyState(
            empty: HTMLElement | null,
            crossDay: HTMLElement | null,
            crossCards: CrossCard[],
            visibleCount: number,
            query: string
        ) {
            if (empty) empty.hidden = !query || visibleCount > 0
            if (!crossDay) return

            if (!query || visibleCount > 0) {
                crossDay.hidden = true
                for (const c of crossCards) c.hidden = true
                return
            }

            let any = false
            for (const c of crossCards) {
                const match = (c.dataset.search || '').includes(query)
                c.hidden = !match
                if (match) any = true
            }
            crossDay.hidden = !any
        }
    }

    customElements.define('schedule-search', ScheduleSearch)
</script>

<style>
    .schedule-search-wrapper {
        display: flex;
        flex: 1 1 200px;
        min-width: 160px;
        margin-left: auto;
    }

    .schedule-search {
        display: flex;
        align-items: center;
        gap: var(--s-2);
        width: 100%;
        max-width: 320px;
        margin-left: auto;
        padding: var(--s-3) var(--s-2);
        border: 1px solid var(--line);
        border-radius: var(--s-3);
        background-color: var(--background);
        color: var(--text);
        transition: border-color var(--animation);

        &:focus-within {
            border-color: var(--brand-solid);
        }

        svg {
            flex-shrink: 0;
            opacity: 0.6;
        }
    }

    .schedule-search-input {
        flex: 1;
        min-width: 0;
        border: 0;
        background: transparent;
        color: inherit;
        font: inherit;
        outline: none;

        &::-webkit-search-cancel-button,
        &::-webkit-search-decoration {
            -webkit-appearance: none;
            appearance: none;
        }
    }

    .schedule-search-clear {
        flex-shrink: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.5rem;
        height: 1.5rem;
        padding: 0;
        margin: 0;
        border: 0;
        border-radius: 999px;
        background: transparent;
        color: inherit;
        opacity: 0.6;
        cursor: pointer;
        transition:
            opacity var(--animation),
            background-color var(--animation);

        &:hover,
        &:focus-visible {
            opacity: 1;
            background-color: var(--line);
            outline: none;
        }
    }
</style>
