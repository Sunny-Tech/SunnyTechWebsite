{
    "name": "sunnytech-astro",
    "type": "module",
    "version": "0.0.1",
    "scripts": {
        "dev": "bun --bun ./node_modules/.bin/astro dev",
        "start": "bun --bun ./node_modules/.bin/astro dev",
        "build": "bun --bun ./node_modules/.bin/astro check && bun --bun ./node_modules/.bin/astro build",
        "preview": "bun --bun ./node_modules/.bin/astro preview",
        "astro": "bun --bun ./node_modules/.bin/astro",
        "prepare": "husky"
    },
    "dependencies": {
        "@astrojs/check": "^0.9.8",
        "@resvg/resvg-js": "^2.6.2",
        "astro": "^6.1.4",
        "astro-md-2": "^2.0.0",
        "firebase": "^11.6.0",
        "lodash": "^4.18.1",
        "markdown-to-txt": "^2.0.1",
        "marked": "^18.0.0",
        "prettier-plugin-astro": "^0.14.1",
        "satori": "^0.26.0",
        "typescript": "^5.9.3"
    },
    "devDependencies": {
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "postcss-nested": "^7.0.2",
        "prettier": "3.8.1"
    },
    "lint-staged": {
        "**/*": "prettier --write --ignore-unknown"
    },
    "trustedDependencies": [
        "@firebase/util",
        "protobufjs"
    ]
}
